<?xml version="1.0"?>
<robot name="rc_car" xmlns:xacro="http://ros.org/wiki/xacro">

  <material name="wood"><color rgba="0.8 0.6 0.4 1.0"/></material>
  <material name="yellow"><color rgba="1.0 0.8 0.0 1.0"/></material>
  <material name="black"><color rgba="0.1 0.1 0.1 1.0"/></material>
  <material name="white"><color rgba="0.9 0.9 0.9 1.0"/></material>
  <material name="blue"><color rgba="0.0 0.0 0.8 1.0"/></material>
  <material name="gray"><color rgba="0.5 0.5 0.5 1.0"/></material>
  <material name="dark_gray"><color rgba="0.3 0.3 0.3 1.0"/></material>
  <material name="red"><color rgba="1.0 0.0 0.0 1.0"/></material>
  <material name="green"><color rgba="0.0 1.0 0.0 1.0"/></material>

  <link name="base_footprint"/>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.02" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.17 0.17 0.005"/></geometry>
      <material name="wood"/>
    </visual>
    <collision>
      <geometry><box size="0.17 0.17 0.005"/></geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="-0.05 0.115 0.0135" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>
  <link name="left_wheel">
    <visual>
      <geometry><cylinder radius="0.0335" length="0.026"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry><cylinder radius="0.0335" length="0.026"/></geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="-0.05 -0.115 0.0135" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>
  
  <link name="right_wheel">
    <visual>
      <geometry><cylinder radius="0.0335" length="0.026"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry><cylinder radius="0.0335" length="0.026"/></geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="left_motor_joint" type="fixed">
    <parent link="base_link"/>
    <child link="left_motor"/>
    <origin xyz="-0.05 0.09 0.0135" rpy="0 0 0"/>
  </joint>
  <link name="left_motor">
    <visual>
      <geometry><box size="0.04 0.024 0.024"/></geometry>
      <material name="yellow"/>
    </visual>
  </link>

  <joint name="left_encoder_joint" type="fixed">
    <parent link="left_motor"/>
    <child link="left_encoder"/>
    <origin xyz="0 -0.014 0" rpy="1.5708 0 0"/>
  </joint>
  <link name="left_encoder">
    <visual>
      <geometry><cylinder radius="0.012" length="0.004"/></geometry>
      <material name="dark_gray"/>
    </visual>
  </link>

  <joint name="right_motor_joint" type="fixed">
    <parent link="base_link"/>
    <child link="right_motor"/>
    <origin xyz="-0.05 -0.09 0.0135" rpy="0 0 0"/>
  </joint>
  <link name="right_motor">
    <visual>
      <geometry><box size="0.04 0.024 0.024"/></geometry>
      <material name="yellow"/>
    </visual>
  </link>

  <joint name="right_encoder_joint" type="fixed">
    <parent link="right_motor"/>
    <child link="right_encoder"/>
    <origin xyz="0 0.014 0" rpy="1.5708 0 0"/>
  </joint>
  <link name="right_encoder">
    <visual>
      <geometry><cylinder radius="0.012" length="0.004"/></geometry>
      <material name="dark_gray"/>
    </visual>
  </link>

  <joint name="arduino_joint" type="fixed">
    <parent link="base_link"/>
    <child link="arduino_board"/>
    <origin xyz="-0.07 0 0.01" rpy="0 0 0"/>
  </joint>
  <link name="arduino_board">
    <visual>
      <geometry><box size="0.07 0.05 0.01"/></geometry>
      <material name="blue"/>
    </visual>
  </link>

  <joint name="esp32_joint" type="fixed">
    <parent link="base_link"/>
    <child link="esp32_board"/>
    <origin xyz="0 0 0.01" rpy="0 0 0"/>
  </joint>
  <link name="esp32_board">
    <visual>
      <geometry><box size="0.05 0.08 0.015"/></geometry>
      <material name="dark_gray"/>
    </visual>
  </link>

  <joint name="battery_joint" type="fixed">
    <parent link="base_link"/>
    <child link="battery"/>
    <origin xyz="0.05 0 0.015" rpy="0 0 0"/>
  </joint>
  <link name="battery">
    <visual>
      <geometry><box size="0.04 0.07 0.02"/></geometry>
      <material name="red"/> </visual>
  </link>

  <joint name="motor_driver_joint" type="fixed">
    <parent link="base_link"/>
    <child link="motor_driver"/>
    <origin xyz="0.04 0.06 0.01" rpy="0 0 0"/>
  </joint>
  <link name="motor_driver">
    <visual>
      <geometry><box size="0.05 0.04 0.015"/></geometry>
      <material name="white"/>
    </visual>
  </link>

  <joint name="converter_joint" type="fixed">
    <parent link="base_link"/>
    <child link="converter"/>
    <origin xyz="0.04 -0.06 0.01" rpy="0 0 0"/>
  </joint>
  <link name="converter">
    <visual>
      <geometry><box size="0.04 0.03 0.015"/></geometry>
      <material name="blue"/>
    </visual>
  </link>

  <joint name="mpu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="mpu6050"/>
    <origin xyz="-0.05 0.04 0.01" rpy="0 0 0"/>
  </joint>
  <link name="mpu6050">
    <visual>
      <geometry><box size="0.015 0.02 0.005"/></geometry>
      <material name="blue"/>
    </visual>
  </link>

  <joint name="left_pillar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="left_pillar"/>
    <origin xyz="-0.08 0.06 0.025" rpy="0 0 0"/>
  </joint>
  <link name="left_pillar">
    <visual>
      <geometry><cylinder radius="0.003" length="0.045"/></geometry>
      <material name="gray"/>
    </visual>
  </link>

  <joint name="right_pillar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="right_pillar"/>
    <origin xyz="-0.08 -0.06 0.025" rpy="0 0 0"/>
  </joint>
  <link name="right_pillar">
    <visual>
      <geometry><cylinder radius="0.003" length="0.045"/></geometry>
      <material name="gray"/>
    </visual>
  </link>

  <joint name="marker_plate_joint" type="fixed">
    <parent link="base_link"/>
    <child link="marker_plate"/>
    <origin xyz="-0.105 0 0.05" rpy="0 0 0"/>
  </joint>
  <link name="marker_plate">
    <visual>
      <geometry><box size="0.06 0.17 0.005"/></geometry>
      <material name="wood"/>
    </visual>
  </link>

  <joint name="aruco_marker_joint" type="fixed">
    <parent link="marker_plate"/>
    <child link="aruco_marker"/>
    <origin xyz="0 0 0.003" rpy="0 0 0"/>
  </joint>
 <link name="aruco_marker">
    <visual>
      <geometry><box size="0.06 0.06 0.001"/></geometry>
      <material name="green"/> </visual>
  </link>

  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_wheel"/>
    <origin xyz="0.07 0 -0.01" rpy="0 0 0"/>
  </joint>
  <link name="caster_wheel">
    <visual>
      <geometry><sphere radius="0.01"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry><sphere radius="0.01"/></geometry>
    </collision>
  </link>

  <gazebo>
    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.23</wheel_separation>
      <wheel_radius>0.0335</wheel_radius>
      <odom_publish_frequency>50</odom_publish_frequency>
      <topic>cmd_vel</topic>
      <odom_topic>odom</odom_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_footprint</child_frame_id>
    </plugin>
  </gazebo>
</robot>
